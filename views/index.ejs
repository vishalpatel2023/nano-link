<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SnapLink | Modern URL Shortener</title>
    
    <link rel="stylesheet" href="/index_style.css">
</head>
<body>

    <header class="app-header">
        <a href="/" class="header-logo" style="text-decoration: none;">SnapLink</a>

        <nav class="header-nav">
            <% if (locals.user) { %>
                <div class="user-profile">
                    <span class="user-email">👤 <%= user.email %></span>
                    <a href="/logout" class="nav-btn logout-btn">Logout</a>
                </div>
            <% } else { %>
                <a href="/login" class="nav-link">Login</a>
                <a href="/register" class="nav-btn">Sign Up</a>
            <% } %>
        </nav>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="shortener-card">
                <div class="logo-area">
                    <span class="logo-icon">🔗</span>
                    <h1>SnapLink</h1>
                    <p class="subtitle">Shorten your messy links instantly.</p>
                </div>

                <form action="/api/url/shorten" method="POST" class="shorten-form">
                    <div class="input-group">
                        <input
                            type="url"
                            name="originalUrl"
                            placeholder="Paste your long link here (e.g., https://google.com)"
                            required
                            autocomplete="off"
                        >
                    </div>

                    <button type="submit" class="btn-submit">
                        Shorten Link <span>⚡</span>
                    </button>
                </form>
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <p>&copy; 2024 SnapLink. All rights reserved.</p>
    </footer>

</body>
</html>