<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Link is Ready! | SnapLink</title>
    <link rel="stylesheet" href="/index_style.css">
</head>
<body>

    <header class="app-header">
        <div class="header-logo">SnapLink</div>
        <nav class="header-nav">
            <% if (locals.user) { %>
                <span class="nav-link" style="cursor: default;">👤 <%= user.email %></span>
                <a href="/logout" class="nav-btn" style="background-color: #ff4d4d; color: white; border: none;">Logout</a>
            <% } else { %>
                <a href="/login" class="nav-link">Login</a>
                <a href="/register" class="nav-btn">Sign Up</a>
            <% } %>
        </nav>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="shortener-card result-card">
                <div class="logo-area">
                    <span class="logo-icon success-icon">🎉</span>
                    <h1>Boom! Shortened.</h1>
                    <p class="subtitle">Your clean, optimized link is ready to share.</p>
                </div>

                <div class="result-box">
                    <a href="/<%= shortCode %>" target="_blank" class="short-url-link" id="shortUrl">http://localhost:3000/<%= shortCode %></a>
                    <button id="copyBtn" class="btn-copy">Copy 📋</button>
                </div>

                <div class="action-area">
                    <a href="/" class="btn-secondary">← Shorten another URL</a>
                </div>
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <p>&copy; 2024 SnapLink. All rights reserved.</p>
    </footer>

    <script>
        const copyBtn = document.getElementById('copyBtn');
        const shortUrlLink = document.getElementById('shortUrl');

        copyBtn.addEventListener('click', async () => {
            const textToCopy = shortUrlLink.innerText.trim();

            try {
                await navigator.clipboard.writeText(textToCopy);
                
                copyBtn.innerText = "Copied! ✅";
                copyBtn.classList.add('copied');

                setTimeout(() => {
                    copyBtn.innerText = "Copy 📋";
                    copyBtn.classList.remove('copied');
                }, 2000);

            } catch (err) {
                console.error("Failed to copy text: ", err);
                alert("Oops, couldn't copy automatically. Please select and copy manually!");
            }
        });
    </script>
</body>
</html>