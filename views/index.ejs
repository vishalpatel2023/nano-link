<!DOCTYPE html>
<html>
<head>
    <title>URL Shortener</title>
</head>
<body>

    <h1>URL Shortener</h1>

    <form action="/api/url/shorten" method="POST">

        <input
            type="text"
            name="originalUrl"
            placeholder="Enter URL"
            required
        >

        <button type="submit">
            Shorten
        </button>

    </form>

</body>
</html>